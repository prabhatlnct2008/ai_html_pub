generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id              String        @id @default(uuid())
  userId          String
  name            String
  slug            String        @unique
  status          String        @default("draft")
  businessContext String        @default("{}")
  competitorData  String        @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  conversation    Conversation?
  pagePlan        PagePlan?
  page            Page?
}

model Conversation {
  id            String   @id @default(uuid())
  projectId     String   @unique
  messages      String   @default("[]")
  workflowState String   @default("intake")
  aiContext     String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PagePlan {
  id        String   @id @default(uuid())
  projectId String   @unique
  planData  String   @default("{}")
  status    String   @default("proposed")
  version   Int      @default(1)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Page {
  id           String        @id @default(uuid())
  projectId    String        @unique
  sectionsJson String        @default("[]")
  globalStyles String        @default("{}")
  renderedHtml String        @default("")
  version      Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions     PageVersion[]
}

model PageVersion {
  id            String   @id @default(uuid())
  pageId        String
  sectionsJson  String
  globalStyles  String
  versionNumber Int
  createdAt     DateTime @default(now())
  page          Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}
